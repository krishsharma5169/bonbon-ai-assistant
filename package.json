{
  "name": "bonbon",
  "version": "1.0.0",
  "description": "BonBon AI Programming Assistant",
  "author": "You",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
  "appId": "com.bonbon.ai",
  "productName": "BonBon",

  "asar": true,

  "asarUnpack": [
    "backend/**/*",
    "frontend/**/*"
  ],

  "files": [
    "backend/**/*",
    "app/**/*",
    "frontend/**/*",
    "main.js",
    "package.json"
  ],

  "win": {
    "target": "nsis"
  }
},
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}